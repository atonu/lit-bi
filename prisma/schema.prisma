// =============================================================================
// BI-Lite — Internal Control Plane Schema
// =============================================================================

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum DatabaseEngine {
  POSTGRESQL
  MYSQL
  MONGODB
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  FAILED
  REVOKED
}

enum ChartType {
  LINE
  BAR
  DONUT
  TABLE
  AREA
  SCATTER
}

enum MessageRole {
  USER
  ASSISTANT
  ERROR
}

// ---------------------------------------------------------------------------
// Organization — multi-tenant root entity
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users       User[]
  connections DatabaseConnection[]
  reports     ReportTemplate[]
  chatSessions ChatSession[]

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// User — belongs to an Organization
// ---------------------------------------------------------------------------

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  name           String
  hashedPassword     String?  @map("hashed_password")
  avatarUrl          String?  @map("avatar_url")
  role               UserRole @default(MEMBER)
  refreshToken       String?  @map("refresh_token")
  resetToken         String?  @map("reset_token")
  resetTokenExpiry   DateTime? @map("reset_token_expiry")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  organizationId String         @map("organization_id") @db.ObjectId
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reports        ReportTemplate[]
  chatSessions   ChatSession[]

  @@index([organizationId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// DatabaseConnection — stores encrypted credentials to the user's DB
// ---------------------------------------------------------------------------

model DatabaseConnection {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  alias             String
  engine            DatabaseEngine   @default(POSTGRESQL)
  // PostgreSQL / MySQL fields
  host              String?
  port              Int?
  dbName            String?          @map("db_name")
  dbUser            String?          @map("db_user")
  encryptedPassword String?          @map("encrypted_password")
  sslEnabled        Boolean          @default(false) @map("ssl_enabled")
  // MongoDB field — full encrypted connection URI
  encryptedUri      String?          @map("encrypted_uri")
  // Unique fingerprint — SHA-256 hash of connection params to prevent duplicates
  uniqueKey         String?          @map("unique_key")
  status            ConnectionStatus @default(PENDING)
  lastTestedAt      DateTime?        @map("last_tested_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Relations
  organizationId String           @map("organization_id") @db.ObjectId
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schemaMetadata SchemaMetadata[]
  chatSessions   ChatSession[]

  @@unique([organizationId, uniqueKey])
  @@index([organizationId])
  @@index([status])
  @@map("database_connections")
}

// ---------------------------------------------------------------------------
// SchemaMetadata — cached introspection of the user's database columns
// ---------------------------------------------------------------------------

model SchemaMetadata {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  tableSchema     String   @default("public") @map("table_schema")
  tableName       String   @map("table_name")
  columnName      String   @map("column_name")
  dataType        String   @map("data_type")
  isNullable      Boolean  @default(true) @map("is_nullable")
  isPrimaryKey    Boolean  @default(false) @map("is_primary_key")
  columnDefault   String?  @map("column_default")
  ordinalPosition Int      @map("ordinal_position")
  introspectedAt  DateTime @default(now()) @map("introspected_at")

  // Relations
  connectionId String             @map("connection_id") @db.ObjectId
  connection   DatabaseConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, tableSchema, tableName, columnName])
  @@index([connectionId])
  @@map("schema_metadata")
}

// ---------------------------------------------------------------------------
// ChatSession — a named conversation thread tied to a DB connection
// ---------------------------------------------------------------------------

model ChatSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String   @default("New Chat")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  connectionId   String?            @map("connection_id") @db.ObjectId
  connection     DatabaseConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  connectionAlias String?           @map("connection_alias")
  organizationId String             @map("organization_id") @db.ObjectId
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String             @map("user_id") @db.ObjectId
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]

  @@index([connectionId])
  @@index([organizationId])
  @@index([userId])
  @@index([updatedAt])
  @@map("chat_sessions")
}

// ---------------------------------------------------------------------------
// ChatMessage — individual message within a ChatSession
// ---------------------------------------------------------------------------

model ChatMessage {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  role        MessageRole
  content     String
  chartResult Json?       @map("chart_result")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  sessionId String      @map("session_id") @db.ObjectId
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ---------------------------------------------------------------------------
// ReportTemplate — saved/default report configurations
// ---------------------------------------------------------------------------

model ReportTemplate {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  title                String
  description          String?
  naturalLanguageQuery String    @map("natural_language_query")
  chartType            ChartType @default(BAR) @map("chart_type")
  defaultFilters       Json?     @map("default_filters")
  isSystemTemplate     Boolean   @default(false) @map("is_system_template")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  organizationId String       @map("organization_id") @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String       @map("created_by_id") @db.ObjectId
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdById])
  @@map("report_templates")
}
